# ===========================================
# Server Configuration
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# MongoDB Configuration
# ===========================================
MONGODB_URI=mongodb://localhost:27017/sortmyscene

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# Seat Reservation Settings
# ===========================================
SEAT_LOCK_TTL_SECONDS=600
RESERVATION_EXPIRY_MINUTES=10

# ===========================================
# JWT & Auth Configuration
# ===========================================
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
ADMIN_SECRET=change_this_to_a_strong_admin_secret
